namespace Livt.Web.Tests.Http

using Livt.Web.Http
using Livt.Net

@Test
component WebServerTest
{
	const INDEX_HTML: byte[] = "<!doctype html><html><body><h1>Livt FPGA Web</h1></body></html>\n".Encode()

	frameIo: EthernetFrameIo
	axi: Axi4LiteEthernetLiteAdapter

	server: WebServer
	generator: HttpResponseGenerator

	new()
	{
		var frameIoMac: byte[6]
		frameIoMac[0] = 0x02
		frameIoMac[1] = 0xAA
		frameIoMac[2] = 0xBB
		frameIoMac[3] = 0xCC
		frameIoMac[4] = 0xDD
		frameIoMac[5] = 0xEE
		this.axi = new Axi4LiteEthernetLiteAdapter()
		this.frameIo = new EthernetFrameIo(
			this.axi,
			frameIoMac)
		this.generator = new HttpResponseGenerator()
		var localMac: byte[6]
		localMac[0] = 0x02
		localMac[1] = 0xAA
		localMac[2] = 0xBB
		localMac[3] = 0xCC
		localMac[4] = 0xDD
		localMac[5] = 0xEE
		var localIp: byte[4]
		localIp[0] = 0x0A
		localIp[1] = 0x00
		localIp[2] = 0x00
		localIp[3] = 0x01
		var localPort: byte[2]
		localPort[0] = 0x00
		localPort[1] = 0x50
		this.server = new WebServer(localMac, localIp, localPort)
	}

	fn CopyFrameToServer()
	{
		this.server.BeginFrame()

		for (var i = 0; i < 128; i++)
		{
			var value = this.frameIo.GetRxByte(i)
			this.server.LoadRxByte(i, value)
		}

		this.frameIo.ConsumeRxFrame()
		this.server.HandleFrame()
	}

	fn CopyResponseToTxFrame()
	{
		var responseLength = this.server.GetResponseLength()
		this.frameIo.BeginTxFrame(responseLength)

		for (var i = 0; i < responseLength; i++)
		{
			var httpBodyByte: logic[8] = 0x00

			if (this.server.IsHttpBodyFrameIndex(i))
			{
				var bodyIndex = this.server.GetHttpBodyIndex(i)
				httpBodyByte = INDEX_HTML[bodyIndex]
			}

			var responseByte = this.server.GetResponseByte(i, httpBodyByte)
			this.frameIo.WriteTxByte(i, responseByte)
		}

		this.frameIo.SubmitTxFrame()
	}

	fn LoadEtherType(etherType: byte[2])
	{
		this.frameIo.LoadRxByte(12, etherType[0])
		this.frameIo.LoadRxByte(13, etherType[1])
	}

	fn LoadEthernetSourceMac(sourceMac: byte[6])
	{
		this.frameIo.LoadRxByte(6, sourceMac[0])
		this.frameIo.LoadRxByte(7, sourceMac[1])
		this.frameIo.LoadRxByte(8, sourceMac[2])
		this.frameIo.LoadRxByte(9, sourceMac[3])
		this.frameIo.LoadRxByte(10, sourceMac[4])
		this.frameIo.LoadRxByte(11, sourceMac[5])
	}

	fn LoadArpEthernetIpv4RequestHeader(header: byte[8])
	{
		this.frameIo.LoadRxByte(14, header[0])
		this.frameIo.LoadRxByte(15, header[1])
		this.frameIo.LoadRxByte(16, header[2])
		this.frameIo.LoadRxByte(17, header[3])
		this.frameIo.LoadRxByte(18, header[4])
		this.frameIo.LoadRxByte(19, header[5])
		this.frameIo.LoadRxByte(20, header[6])
		this.frameIo.LoadRxByte(21, header[7])
	}

	fn LoadArpSenderMac(senderMac: byte[6])
	{
		this.frameIo.LoadRxByte(22, senderMac[0])
		this.frameIo.LoadRxByte(23, senderMac[1])
		this.frameIo.LoadRxByte(24, senderMac[2])
		this.frameIo.LoadRxByte(25, senderMac[3])
		this.frameIo.LoadRxByte(26, senderMac[4])
		this.frameIo.LoadRxByte(27, senderMac[5])
	}

	fn LoadArpSenderIp(senderIp: byte[4])
	{
		this.frameIo.LoadRxByte(28, senderIp[0])
		this.frameIo.LoadRxByte(29, senderIp[1])
		this.frameIo.LoadRxByte(30, senderIp[2])
		this.frameIo.LoadRxByte(31, senderIp[3])
	}

	fn LoadArpTargetIp(targetIp: byte[4])
	{
		this.frameIo.LoadRxByte(38, targetIp[0])
		this.frameIo.LoadRxByte(39, targetIp[1])
		this.frameIo.LoadRxByte(40, targetIp[2])
		this.frameIo.LoadRxByte(41, targetIp[3])
	}

	fn LoadIpv4FixedTcpHeader(ipHeader: byte[4])
	{
		this.frameIo.LoadRxByte(14, ipHeader[0])
		this.frameIo.LoadRxByte(20, ipHeader[1])
		this.frameIo.LoadRxByte(21, ipHeader[2])
		this.frameIo.LoadRxByte(23, ipHeader[3])
	}

	fn LoadIpv4SourceIp(sourceIp: byte[4])
	{
		this.frameIo.LoadRxByte(26, sourceIp[0])
		this.frameIo.LoadRxByte(27, sourceIp[1])
		this.frameIo.LoadRxByte(28, sourceIp[2])
		this.frameIo.LoadRxByte(29, sourceIp[3])
	}

	fn LoadIpv4DestinationIp(destinationIp: byte[4])
	{
		this.frameIo.LoadRxByte(30, destinationIp[0])
		this.frameIo.LoadRxByte(31, destinationIp[1])
		this.frameIo.LoadRxByte(32, destinationIp[2])
		this.frameIo.LoadRxByte(33, destinationIp[3])
	}

	fn LoadTcpSourcePort(sourcePort: byte[2])
	{
		this.frameIo.LoadRxByte(34, sourcePort[0])
		this.frameIo.LoadRxByte(35, sourcePort[1])
	}

	fn LoadTcpDestinationPort(destinationPort: byte[2])
	{
		this.frameIo.LoadRxByte(36, destinationPort[0])
		this.frameIo.LoadRxByte(37, destinationPort[1])
	}

	fn LoadTcpSeqNum(seqNum: byte[4])
	{
		this.frameIo.LoadRxByte(38, seqNum[0])
		this.frameIo.LoadRxByte(39, seqNum[1])
		this.frameIo.LoadRxByte(40, seqNum[2])
		this.frameIo.LoadRxByte(41, seqNum[3])
	}

	fn LoadTcpDataOffsetAndFlags(dataOffsetAndFlags: byte[2])
	{
		this.frameIo.LoadRxByte(46, dataOffsetAndFlags[0])
		this.frameIo.LoadRxByte(47, dataOffsetAndFlags[1])
	}

	fn LoadTcpPayload6(payload: byte[6])
	{
		this.frameIo.LoadRxByte(54, payload[0])
		this.frameIo.LoadRxByte(55, payload[1])
		this.frameIo.LoadRxByte(56, payload[2])
		this.frameIo.LoadRxByte(57, payload[3])
		this.frameIo.LoadRxByte(58, payload[4])
		this.frameIo.LoadRxByte(59, payload[5])
	}

	@Test
	fn IgnoresUnsupportedFrame()
	{
		var unsupportedEtherType: byte[2]
		unsupportedEtherType[0] = 0x12
		unsupportedEtherType[1] = 0x34

		this.LoadEtherType(unsupportedEtherType)
		this.frameIo.SubmitRxFrame()

		this.CopyFrameToServer()

		assert this.server.HasResponse() == false
		assert this.server.GetResponseKind() == 0
		assert this.server.GetResponseLength() == 0
		assert this.frameIo.HasTxFrame() == false
	}

	@Test
	fn RespondsToArpRequest()
	{
		var arpEthernetIpv4Request: byte[8]
		arpEthernetIpv4Request[0] = 0x00
		arpEthernetIpv4Request[1] = 0x01
		arpEthernetIpv4Request[2] = 0x08
		arpEthernetIpv4Request[3] = 0x00
		arpEthernetIpv4Request[4] = 0x06
		arpEthernetIpv4Request[5] = 0x04
		arpEthernetIpv4Request[6] = 0x00
		arpEthernetIpv4Request[7] = 0x01

		var clientMac: byte[6]
		clientMac[0] = 0x02
		clientMac[1] = 0x10
		clientMac[2] = 0x20
		clientMac[3] = 0x30
		clientMac[4] = 0x40
		clientMac[5] = 0x50

		var clientIp: byte[4]
		clientIp[0] = 0x0A
		clientIp[1] = 0x00
		clientIp[2] = 0x00
		clientIp[3] = 0x02

		var localIp: byte[4]
		localIp[0] = 0x0A
		localIp[1] = 0x00
		localIp[2] = 0x00
		localIp[3] = 0x01

		this.LoadArpEthernetIpv4RequestHeader(arpEthernetIpv4Request)
		this.LoadArpSenderMac(clientMac)
		this.LoadArpSenderIp(clientIp)
		this.LoadArpTargetIp(localIp)
		this.frameIo.SubmitRxFrame()

		this.CopyFrameToServer()

		assert this.server.HasResponse() == true
		assert this.server.GetResponseKind() == 1
		assert this.server.GetResponseLength() == 60
		assert this.server.GetResponseByte(0, 0x00) == 0x02
		assert this.server.GetResponseByte(5, 0x00) == 0x50
		assert this.server.GetResponseByte(6, 0x00) == 0x02
		assert this.server.GetResponseByte(7, 0x00) == 0xAA
		assert this.server.GetResponseByte(12, 0x00) == 0x08
		assert this.server.GetResponseByte(13, 0x00) == 0x06
		assert this.server.GetResponseByte(21, 0x00) == 0x02

		this.CopyResponseToTxFrame()

		assert this.frameIo.HasTxFrame() == true
		assert this.frameIo.GetTxLength() == 60
		assert this.frameIo.GetTxByte(0) == 0x02
		assert this.frameIo.GetTxByte(5) == 0x50
		assert this.frameIo.GetTxByte(6) == 0x02
		assert this.frameIo.GetTxByte(7) == 0xAA
		assert this.frameIo.GetTxByte(12) == 0x08
		assert this.frameIo.GetTxByte(13) == 0x06
		assert this.frameIo.GetTxByte(21) == 0x02
	}

	@Test
	fn RespondsToHttpGetRootRequest()
	{
		this.server.SetBodyConfig(1, 64, 717318)

		var httpGetRoot = "GET / ".Encode()
		var response = "HTTP/1.0 200 OK".Encode()
		var content = "<!doctype html><html><body><h1>Livt FPGA Web</h1></body></html>".Encode()

		var clientMac: byte[6]
		clientMac[0] = 0x02
		clientMac[1] = 0x10
		clientMac[2] = 0x20
		clientMac[3] = 0x30
		clientMac[4] = 0x40
		clientMac[5] = 0x50

		var etherTypeIpv4: byte[2]
		etherTypeIpv4[0] = 0x08
		etherTypeIpv4[1] = 0x00

		var fixedIpv4TcpHeader: byte[4]
		fixedIpv4TcpHeader[0] = 0x45
		fixedIpv4TcpHeader[1] = 0x40
		fixedIpv4TcpHeader[2] = 0x00
		fixedIpv4TcpHeader[3] = 0x06

		var clientIp: byte[4]
		clientIp[0] = 0x0A
		clientIp[1] = 0x00
		clientIp[2] = 0x00
		clientIp[3] = 0x02

		var localIp: byte[4]
		localIp[0] = 0x0A
		localIp[1] = 0x00
		localIp[2] = 0x00
		localIp[3] = 0x01

		var clientPort: byte[2]
		clientPort[0] = 0xC0
		clientPort[1] = 0x01

		var httpPort: byte[2]
		httpPort[0] = 0x00
		httpPort[1] = 0x50

		var clientSeq: byte[4]
		clientSeq[0] = 0xAA
		clientSeq[1] = 0xBB
		clientSeq[2] = 0xCC
		clientSeq[3] = 0xDD

		// Send SYN
		var tcpSyn: byte[2]
		tcpSyn[0] = 0x50
		tcpSyn[1] = 0x02

		this.LoadEthernetSourceMac(clientMac)
		this.LoadEtherType(etherTypeIpv4)
		this.LoadIpv4FixedTcpHeader(fixedIpv4TcpHeader)
		this.LoadIpv4SourceIp(clientIp)
		this.LoadIpv4DestinationIp(localIp)
		this.LoadTcpSourcePort(clientPort)
		this.LoadTcpDestinationPort(httpPort)
		this.LoadTcpSeqNum(clientSeq)
		this.LoadTcpDataOffsetAndFlags(tcpSyn)
		this.frameIo.SubmitRxFrame()

		this.CopyFrameToServer()

		assert this.server.GetResponseKind() == 3

		// Send ACK
		var tcpAck: byte[2]
		tcpAck[0] = 0x50
		tcpAck[1] = 0x10

		this.LoadTcpDataOffsetAndFlags(tcpAck)
		this.frameIo.SubmitRxFrame()

		this.CopyFrameToServer()

		// Send HTTP GET
		var tcpPshAck: byte[2]
		tcpPshAck[0] = 0x50
		tcpPshAck[1] = 0x18

		this.LoadTcpDataOffsetAndFlags(tcpPshAck)
		this.LoadTcpPayload6(httpGetRoot)
		this.frameIo.SubmitRxFrame()

		this.CopyFrameToServer()

		var indexLength = 64
		var bodyOffset = this.generator.GetBodyFrameOffset(indexLength)
		var expectedResponseLength = this.generator.GetResponseFrameLength(indexLength)

		assert this.server.HasResponse() == true
		assert this.server.GetResponseKind() == 4
		assert this.server.GetResponseLength() == expectedResponseLength
		assert this.server.GetResponseByte(0, 0x00) == 0x02
		assert this.server.GetResponseByte(6, 0x00) == 0x02
		assert this.server.GetResponseByte(12, 0x00) == 0x08
		assert this.server.GetResponseByte(14, 0x00) == 0x45
		assert this.server.GetResponseByte(24, 0x00) == 0x26
			assert this.server.GetResponseByte(25, 0x00) == 0x4D
		assert this.server.GetResponseByte(34, 0x00) == 0x00
		assert this.server.GetResponseByte(36, 0x00) == 0xC0
		assert this.server.GetResponseByte(47, 0x00) == 0x19
		assert this.server.GetResponseByte(54, 0x00) == response[0]
		assert this.server.GetResponseByte(bodyOffset, content[0]) == content[0]

		this.CopyResponseToTxFrame()

		assert this.frameIo.HasTxFrame() == true
		assert this.frameIo.GetTxLength() == expectedResponseLength
		assert this.frameIo.GetTxByte(0) == 0x02
		assert this.frameIo.GetTxByte(6) == 0x02
		assert this.frameIo.GetTxByte(12) == 0x08
		assert this.frameIo.GetTxByte(14) == 0x45
		assert this.frameIo.GetTxByte(24) == 0x26
			assert this.frameIo.GetTxByte(25) == 0x4D
		assert this.frameIo.GetTxByte(34) == 0x00
		assert this.frameIo.GetTxByte(36) == 0xC0
		assert this.frameIo.GetTxByte(47) == 0x19
		assert this.frameIo.GetTxByte(54) == response[0]
		assert this.frameIo.GetTxByte(bodyOffset) == content[0]
	}
}
